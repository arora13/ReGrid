VITE_MAPBOX_TOKEN=
# Server-only (never prefix with VITE_): copilot intent + short plain-English summary via Anthropic.
# Also set spend limits in the Anthropic console — the app cannot cap your invoice.
ANTHROPIC_API_KEY=
# Optional override (default: claude-3-5-haiku-20241022 — cheapest default for short JSON)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Max output tokens per intent call (256–512, default 384). Lower = cheaper.
# ANTHROPIC_MAX_OUTPUT_TOKENS=384
# Rate limits (sliding window, per server isolate). One Anthropic HTTP request per copilot run — no loops.
# ANTHROPIC_RL_WINDOW_MS=60000
# ANTHROPIC_RL_PER_IP_MAX=8
# Optional global cap per window (0 = disabled). Helps cap burst if many users hit one worker.
# ANTHROPIC_RL_GLOBAL_MAX_PER_WINDOW=0
VITE_CONVEX_URL=
VITE_SPATIAL_API_URL=http://localhost:8000
